datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Word {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  entry_in_english  String
  sub_entries       String[]
  categories        Int[]
  entry_type        String?
}

